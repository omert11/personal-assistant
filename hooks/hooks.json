{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/load-rules.sh",
            "statusMessage": "Kurallar yukleniyor..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/init-check.sh",
            "statusMessage": "Proje yapilandirmasi kontrol ediliyor..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v pwsh >/dev/null 2>&1 && pwsh -File ${CLAUDE_PLUGIN_ROOT}/scripts/init-check.ps1 || exit 0",
            "statusMessage": "Proje yapilandirmasi kontrol ediliyor (pwsh)..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Oturum basladi. init-check script sonucunu oku. INIT_MISSING varsa eksikleri kullaniciya bildir ve /project-init onerisi sun. INIT_MALFORMED varsa: ilgili satir CLAUDE.local.md de VAR ama degeri okunamiyor (format hatali) — kullaniciya hangi alanin formatinin bozuk oldugunu bildir, dogru formati ornekle goster (orn. Obsidian Folder icin: - **Obsidian Folder**: <isim>) ve duzeltmeyi oner. INIT_OK ise sessizce devam et.'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/obsidian-context.sh",
            "statusMessage": "Obsidian MOC yukleniyor..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-obsidian-daily.sh",
            "statusMessage": "Obsidian daily yukleniyor..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/userprompt-obsidian-hint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/stop-obsidian-daily.sh"
          }
        ]
      }
    ]
  }
}
